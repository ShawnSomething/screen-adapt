{
  "name": "screen-adapt",
  "version": "1.0.0",
  "description": "A PostCSS plugin that compiles custom screen at-rules into standard media queries.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShawnSomething/screen-adapt.git"
  },
  "keywords": ["postcss", "postcss-plugin", "responsive", "css", "media-queries"],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ShawnSomething/screen-adapt/issues"
  },
  "homepage": "https://github.com/ShawnSomething/screen-adapt#readme",
  "peerDependencies": {
    "postcss": "^8.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "postcss": "^8.5.10",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
