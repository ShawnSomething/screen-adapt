{
  "name": "screen-adapt",
  "displayName": "screen-adapt",
  "description": "A VS Code extension that makes responsive CSS the default workflow. Write CSS once, declare which screen sizes you care about, and the extension scaffolds the responsive variants automatically",
  "publisher": "ShawnKhoo",
  "version": "0.0.4",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onLanguage:javascriptreact", "onLanguage:typescriptreact"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "screen-adapt.scaffoldVariants",
        "title": "Screen Adapt: Add screen variants"
      },
      {
        "command": "screen-adapt.globalScan",
        "title": "Screen Adapt: Adapt all selectors"
      },
      {
        "command": "screen-adapt.initialise",
        "title": "Screen Adapt: Initialise @screens"
      },
      {
        "command": "screen-adapt.tailwind.addVariants",
        "title": "Screen Adapt: Add Tailwind variants"
      },
      {
        "command": "screen-adapt.tailwind.adaptAll",
        "title": "Screen Adapt: Adapt all elements"
      }
    ],
    "keybindings": [
      {
        "command": "screen-adapt.scaffoldVariants",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "editorLangId == css"
      },
      {
        "command": "screen-adapt.globalScan",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorLangId == css"
      },
      {
        "command": "screen-adapt.initialise",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorLangId == css"
      },
      {
        "command": "screen-adapt.tailwind.addVariants",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorLangId == javascriptreact || editorLangId == typescriptreact"
      },
      {
        "command": "screen-adapt.tailwind.adaptAll",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorLangId == javascriptreact || editorLangId == typescriptreact"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "screen-adapt.scaffoldVariants",
          "when": "editorLangId == css",
          "group": "9_cutcopypaste"         
        },
        {
          "command": "screen-adapt.tailwind.addVariants",
          "when": "editorLangId == javascriptreact || editorLangId == typescriptreact",
          "group": "9_cutcopypaste"
        },
        {
          "command": "screen-adapt.tailwind.adaptAll",
          "when": "editorLangId == javascriptreact || editorLangId == typescriptreact",
          "group": "9_cutcopypaste"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShawnSomething/screen-adapt.git"
  }
}
